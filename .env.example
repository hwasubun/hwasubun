# FRED API 키 (선택 — 없으면 FRED 공개 CSV로 자동 폴백)
# 발급: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# 텔레그램 알림 (선택 — 미설정 시 알림만 생략되고 나머지는 정상 동작)
# 1) @BotFather 에서 봇 생성 → 토큰 복사
# 2) 봇에게 아무 메시지 전송 후 https://api.telegram.org/bot<토큰>/getUpdates 에서 chat id 확인
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
